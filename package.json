{
  "name": "doodle-frontend-engineer-challenge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "start": "vite preview --host 0.0.0.0 --port 3001",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch --watchman=false",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
